# Server Configuration
NODE_ENV=development
PORT=4000
CORS_ORIGIN=*

# Authentication
# IMPORTANT: Change this to a secure random string in production
AUTH_TOKEN_SECRET=dev-insecure-secret
ACCESS_TOKEN_TTL_HOURS=168

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=money_manager

# PostgreSQL Checkpointer Configuration
POSTGRES_URL=postgresql://postgres:matkhaukholam123@127.0.0.1:5432/postgres


# AI Services
# Get your API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Get your API key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Email Configuration (Nodemailer)
# Gmail SMTP requires an App Password (not your regular Google password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password
